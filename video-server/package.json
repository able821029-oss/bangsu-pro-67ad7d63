{
  "name": "sms-video-server",
  "version": "5.0.0",
  "description": "SMS 쇼츠 영상 서버사이드 렌더링 (Remotion + BullMQ)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "worker": "node worker.js",
    "dev": "nodemon index.js",
    "dev:worker": "nodemon worker.js",
    "bundle": "npx remotion bundle remotion/index.tsx --out-dir remotion-bundle",
    "test:queue": "node --test tests/queue.test.js",
    "test:ffmpeg": "node --test tests/ffmpegRenderer.test.js",
    "test": "node --test tests/"
  },
  "dependencies": {
    "@remotion/renderer": "4.0.447",
    "@remotion/bundler": "4.0.447",
    "@remotion/cli": "4.0.447",
    "@supabase/supabase-js": "^2.39.0",
    "bullmq": "^5.26.0",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0",
    "ioredis": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.447",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
