# Cloudflare Pages — 전역 보안 헤더
# 배포 시 public/_headers는 자동으로 읽혀 모든 응답에 적용됩니다.
# docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self), payment=(self)
  Cross-Origin-Opener-Policy: same-origin
  X-DNS-Prefetch-Control: on
  # Content-Security-Policy — 2026-04-24 도입 · 2026-04-25 connect-src 보강.
  # 'unsafe-inline' style은 shadcn/ui + Tailwind 런타임 스타일용 — 점진적 제거 과제.
  # connect-src 보강 이유:
  #   - data: / blob: → uploadPostPhoto가 dataUrl을 fetch→Blob 변환
  #   - nominatim.openstreetmap.org → 위치 역지오코딩
  #   - fonts.googleapis.com / fonts.gstatic.com → Service Worker의 폰트 캐싱
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://dapi.kakao.com https://developers.kakao.com https://www.googletagmanager.com https://www.clarity.ms https://browser.sentry-cdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' data: blob: https://*.supabase.co wss://*.supabase.co https://*.railway.app https://api.elevenlabs.io https://www.google-analytics.com https://*.clarity.ms https://*.sentry.io https://nominatim.openstreetmap.org https://fonts.googleapis.com https://fonts.gstatic.com; frame-src 'self' https://*.kakao.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'

# 정적 에셋은 장기 캐시
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 아이콘 · OG 이미지 · favicon
/icon-*.png
  Cache-Control: public, max-age=86400
/favicon.svg
  Cache-Control: public, max-age=86400
/og-image.*
  Cache-Control: public, max-age=86400

# Service Worker는 항상 최신 조회 (업데이트 감지용)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# index.html도 no-cache — CF가 자동으로 처리하지만 명시
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/
  Cache-Control: no-cache, no-store, must-revalidate
