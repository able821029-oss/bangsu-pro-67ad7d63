# Cloudflare Pages — 전역 보안 헤더
# 배포 시 public/_headers는 자동으로 읽혀 모든 응답에 적용됩니다.
# docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self), payment=(self)
  Cross-Origin-Opener-Policy: same-origin
  X-DNS-Prefetch-Control: on

# 정적 에셋은 장기 캐시
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 아이콘 · OG 이미지 · favicon
/icon-*.png
  Cache-Control: public, max-age=86400
/favicon.svg
  Cache-Control: public, max-age=86400
/og-image.*
  Cache-Control: public, max-age=86400

# Service Worker는 항상 최신 조회 (업데이트 감지용)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# index.html도 no-cache — CF가 자동으로 처리하지만 명시
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/
  Cache-Control: no-cache, no-store, must-revalidate
