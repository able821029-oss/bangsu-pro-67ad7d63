# Supabase (publishable/anon key — safe to expose in client)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# Admin login credentials
# NOTE: Vite embeds VITE_* vars into the client bundle at build time.
# These values will be visible in compiled JS. For real security, use
# server-side auth (Supabase Auth + RLS). This is only to avoid hardcoding
# defaults in source.
VITE_ADMIN_ID=""
VITE_ADMIN_PW=""

# ─────────────────── Analytics / 트래킹 ───────────────────
# Google Analytics 4 Measurement ID (예: G-XXXXXXXXXX)
VITE_GA_ID=""

# Microsoft Clarity Project ID (clarity.microsoft.com)
VITE_CLARITY_ID=""

# Sentry 에러 트래킹 DSN (sentry.io)
VITE_SENTRY_DSN=""

# ─────────────────── 카카오 공유 / 로그인 ───────────────────
# Kakao Developers → 앱 → JavaScript 키
VITE_KAKAO_JAVASCRIPT_KEY=""
