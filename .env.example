# ============================================================
# SMS 앱 환경변수 — 출시 전 빈 값을 모두 채워야 함
# ============================================================
#
# 보안 주의:
#   VITE_* 접두사는 빌드 시점에 클라이언트 JS 번들에 그대로 박힘.
#   민감한 비밀키는 절대 VITE_* 로 두지 말고, Supabase Edge Function Secrets
#   (https://supabase.com/dashboard/project/_/settings/functions) 에 등록.
# ------------------------------------------------------------

# ─────────────────── 1) Supabase (필수) ───────────────────
# Anon/Publishable 키만 사용 — service_role 키는 절대 클라이언트에 노출 금지
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# ─────────────────── 2) 관리자 페이지 (선택) ───────────────────
# /admin 진입 임시 자격증명 — 실서비스 출시 전 Supabase Auth + RLS 로 교체 권장
VITE_ADMIN_ID=""
VITE_ADMIN_PW=""

# ─────────────────── 3) 회사 정보 (출시 전 필수) ───────────────────
# 클라이언트 사업자 정보 수령 후 채움. 빈 값이면 src/config/companyInfo.ts 의
# 기본 placeholder 가 노출되며, 개인정보처리방침에 [미등록] 표시가 뜸.
VITE_COMPANY_LEGAL_NAME=""              # 정식 상호 (예: "주식회사 홍길동건설")
VITE_COMPANY_SERVICE_NAME="SMS"         # 서비스 약식명 (마케팅용)
VITE_COMPANY_REPRESENTATIVE=""          # 대표자명
VITE_COMPANY_BUSINESS_NUMBER=""         # 사업자등록번호 (예: "123-45-67890")
VITE_COMPANY_ECOMMERCE_NUMBER=""        # 통신판매업 신고번호 (예: "제2026-서울강남-12345호")
VITE_COMPANY_ADDRESS=""                 # 사업장 주소 (도로명 주소)
VITE_COMPANY_CS_EMAIL=""                # 고객센터 이메일
VITE_COMPANY_CS_PHONE=""                # 고객센터 전화번호
VITE_COMPANY_CS_HOURS="평일 10:00 ~ 18:00 (주말·공휴일 제외)"
VITE_COMPANY_PRIVACY_OFFICER_NAME=""    # 개인정보 보호책임자명
VITE_COMPANY_PRIVACY_OFFICER_EMAIL=""   # 개인정보 보호책임자 이메일
VITE_PRIVACY_POLICY_EFFECTIVE_DATE="2026년 4월 25일"

# ─────────────────── 4) Analytics / 트래킹 (선택) ───────────────────
# 키가 비어있으면 자동 비활성화 (no-op). 출시 후 가입해서 추가 가능.
VITE_GA_ID=""              # Google Analytics 4 Measurement ID (예: G-XXXXXXXXXX)
VITE_CLARITY_ID=""         # Microsoft Clarity Project ID
VITE_SENTRY_DSN=""         # Sentry 에러 트래킹 DSN

# ─────────────────── 5) 카카오 공유 / 로그인 (선택) ───────────────────
VITE_KAKAO_JAVASCRIPT_KEY=""

# ============================================================
# Edge Function Secrets (Supabase 대시보드에 등록 — VITE_ 접두사 없음)
# ============================================================
# 아래는 .env 파일이 아닌 Supabase Project Settings → Edge Functions → Secrets
# 에 등록해야 하는 서버 전용 시크릿 목록. 참고용으로 여기 명시.
# ------------------------------------------------------------
#
# ANTHROPIC_API_KEY=          # Claude (필수)
# GEMINI_API_KEY=             # Gemini (선택, AI 폴백)
# ELEVENLABS_API_KEY=         # ElevenLabs TTS (필수, 유료)
# SHOTSTACK_API_KEY=          # Shotstack (필수)
# SHOTSTACK_HOST=             # Shotstack 모드 전환 (아래 섹션 참고)
# SHOTSTACK_BGM_URL=          # 엔딩 BGM 공개 mp3 URL (선택)
# SUPABASE_SERVICE_ROLE_KEY=  # 서버 전용 RLS 우회 키 (auth-edge 용)
# CRON_SECRET=                # cleanup-shorts-assets cron 인증 헤더값
# OPS_SLACK_WEBHOOK_URL=      # ops-alert 운영 알림 (선택)
#
# ─── Shotstack 모드 전환 ─────────────────────────────────────
# 무료 stage (워터마크 있음, 기본값):
#   SHOTSTACK_HOST 미설정 또는 "https://api.shotstack.io/edit/stage"
#
# 유료 prod (워터마크 없음, 출시 시 전환):
#   1. shotstack.io 결제 → Production API Key 발급
#   2. SHOTSTACK_API_KEY 를 prod 키로 교체
#   3. SHOTSTACK_HOST=https://api.shotstack.io/edit/v1
#   4. (재배포 불필요 — env 즉시 반영)
# ============================================================
